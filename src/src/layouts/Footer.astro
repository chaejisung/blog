---
// src/components/Footer.astro
import { IconBrandGithub, IconBrandLinkedin } from '@tabler/icons-react';

const GITHUB_URL = 'https://github.com/chaejisung';
const LINKEDIN_URL = '#';
---

<footer>
  <div class="footer-container">
    <div class="footer-left">
      <span class="footer-logo">&lt;/&gt;</span>
      <span class="footer-title">TraceBack</span>
    </div>

    <div class="footer-center">
      <p>© 2025 ChaeJisung. All rights reserved.</p>
    </div>

    <div class="footer-right">
      <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer" class="icon-link">
        <IconBrandGithub className="footer-icon" />
      </a>
      <a href={LINKEDIN_URL} target="_blank" rel="noopener noreferrer" class="icon-link">
        <IconBrandLinkedin className="footer-icon" />
      </a>
    </div>
  </div>
</footer>

<style>
  footer {
    width: 100%;
    padding: 2rem 2rem;
    background: #fff;
    border-top: 2px solid #888;
    font-family: 'Poppins', sans-serif;
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    color: #444;
    font-size: 0.95rem;
    gap: 1rem;
  }

  .footer-left {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 600;
    color: black;
  }
  
  .footer-logo {
    font-family: monospace;
    font-size: 1.2rem;
  }

  .footer-center {
    flex: 1;
    text-align: center;
    color: #6b7280;
  }

  .footer-right {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .footer-icon {
    width: 22px;
    height: 22px;
    color: #111;
  }

  @media (max-width: 640px) {
    .footer-container {
      flex-direction: column;
      text-align: center;
      gap: 0.8rem;
    }

    .footer-center {
      order: 2;
    }

    .footer-left,
    .footer-right {
      order: 1;
    }
  }
</style>
