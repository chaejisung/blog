---
import { IconBrandGithub, IconBrandLinkedin } from '@tabler/icons-react';

const GITHUB_URL = 'https://github.com/chaejisung';
const LINKEDIN_URL = '#';
---

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap" rel="stylesheet">

<header>
  <div class="container">
    <div class="title">
      <span class="blog-name">TraceBack</span>
    </div>

    <nav class="nav">
      <a href="/" class="hover-underline">Home</a>
      <a href="/info" class="hover-underline">Info</a>
      <a href="/project" class="hover-underline">Project</a>
      <a href="/post" class="hover-underline">Post</a>
      <a href="/lab" class="hover-underline">Lab</a>
      <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer" class="icon-link">
        <IconBrandGithub className="icon" />
      </a>
      <a href={LINKEDIN_URL} target="_blank" rel="noopener noreferrer" class="icon-link">
        <IconBrandLinkedin className="icon" />
      </a>
    </nav>
  </div>
</header>

<style>
  header {
    background-color: black;
    color: white;
    font-family: 'Poppins', sans-serif;

    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;

    border-bottom: 1px solid #444;
  }

  .container {
    margin: 0 auto;
    min-width: 400px;
    max-width: 1200px;
    padding: 0 1rem;
    padding-bottom: 0.8rem;
    height: 110px;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
  }

  .title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .blog-name {
    font-size: 2.4rem;
    font-weight: bold;
  }

  .nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    align-items: center;
    justify-content: flex-end;
  }

  .nav a {
    text-decoration: none;
    color: white;
    font-size: 1.6rem;
    font-weight: 500;
    position: relative;
  }

  .hover-underline::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -3px;
    height: 2px;
    width: 0;
    background-color: white;
    transition: width 0.3s ease;
  }

  .hover-underline:hover::after {
    width: 100%;
  }

  .icon {
    width: 28px;
    height: 28px;
    margin-bottom: 0.4rem;
  }

  .icon-link {
    display: flex;
    align-items: center;
  }

  @media (max-width: 640px) {
    .nav {
      gap: 0.75rem;
      flex-wrap: wrap;
      justify-content: flex-start;
    }

    .container {
      flex-direction: column;
      justify-content: center;
      height: auto;
      padding-top: 0.75rem;
      padding-bottom: 0.75rem;
    }

    .title {
      margin-bottom: 0.5rem;
    }
  }
</style>
